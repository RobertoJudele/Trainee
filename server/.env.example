PORT=8000
NODE_ENV=development
TRUST_PROXY=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=trainee
DB_USER=postgres
DB_PASS=change_me

JWT_SECRET=change_me
JWT_RESET_SECRET=change_me_reset
CHECKIN_CODE_SECRET=change_me_checkin

SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password_or_app_password

BILLING_MODE=revenuecat_only

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:8081/checkout?success=true&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:8081/checkout?canceled=true
STRIPE_PORTAL_RETURN_URL=http://localhost:8081/checkout?success=true

REVENUECAT_SECRET_API_KEY=rc_secret_...
REVENUECAT_WEBHOOK_AUTH=change_me_webhook_auth
REVENUECAT_ENTITLEMENT_ID=trainer_subscription
REVENUECAT_API_URL=https://api.revenuecat.com/v1

# Object storage (Cloudflare R2 — S3-compatible). These are R2 API token creds.
AWS_ACCESS_KEY_ID=r2_access_key_id
AWS_SECRET_ACCESS_KEY=r2_secret_access_key
AWS_S3_BUCKET=trainee-assets
# R2 S3 API endpoint for your account:
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Public base URL for serving objects (r2.dev dev URL or a custom domain):
S3_PUBLIC_URL=https://pub-xxxx.r2.dev

GOOGLE_PLACES_API_KEY=AIza...

# Strict unknown-field policy: monitor | enforce
INPUT_UNKNOWN_FIELDS_MODE=monitor

# Rate limiting overrides
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=25
RATE_LIMIT_EMAIL_WINDOW_MS=900000
RATE_LIMIT_EMAIL_MAX=15
RATE_LIMIT_CHECKOUT_WINDOW_MS=60000
RATE_LIMIT_CHECKOUT_MAX=30
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=600